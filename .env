# ── OPTION 1: Databricks Foundation Model APIs ────────────────────────────────
DATABRICKS_HOST=your-databricks-host-url
DATABRICKS_TOKEN=your-databricks-personal-access-token
#DATABRICKS_MODEL_ENDPOINT=databricks-claude-sonnet-5
DATABRICKS_MODEL_ENDPOINT=databricks-claude-haiku-4-5

# ── OPTION 2: Azure OpenAI (not set yet) ──────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── OPTION 3: Public OpenAI (not set yet) ─────────────────────────────────────
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-4o-mini

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=your-jira-instance.atlassian.net
JIRA_USER_EMAIL=your jira-user-email
JIRA_API_TOKEN=your-jira-api-token
JIRA_ISSUE_KEY=ABCD-5928

# ── Azure DevOps ──────────────────────────────────────────────────────────────
# Auth uses your existing 'az login' session (Azure AD) — no PAT needed.
# Run 'az login' if your session expires.
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-organization
AZURE_DEVOPS_PROJECT=your-project
AZURE_DEVOPS_REPO=your-repo
AZURE_DEVOPS_DEFAULT_BRANCH=main
AZURE_DEVOPS_APP_FOLDER=your-app-folder
AZURE_DEVOPS_PIPELINE_NAME=your-pipeline-name

# ── Flask app smoke test URL (fill in when ready) ─────────────────────────────
# APP_SERVICE_URL=https://your-app.azurewebsites.net

# ── Runtime ───────────────────────────────────────────────────────────────────
USE_LLM=true
