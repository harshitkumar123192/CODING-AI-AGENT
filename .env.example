# ── OPTION 1 (recommended): Databricks Foundation Model APIs ────────────────
# Your workspace already has Claude Sonnet 5, Claude Opus 4.7, GPT OSS 120B etc.
# How to get these values:
#   DATABRICKS_HOST  : the URL in your browser when logged into Databricks
#                      e.g. https://abc.azuredatabricks.net
#   DATABRICKS_TOKEN : Databricks → top-right avatar → Settings
#                      → Developer → Access tokens → Generate new token
#   DATABRICKS_MODEL_ENDPOINT : the endpoint Name from Serving page
#                      e.g. databricks-claude-sonnet-5
#
# DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
# DATABRICKS_TOKEN=your_databricks_personal_access_token
# DATABRICKS_MODEL_ENDPOINT=databricks-claude-sonnet-5

# ── OPTION 2: Azure OpenAI ───────────────────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── OPTION 3: Public OpenAI ──────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-4o-mini

# Jira (Atlassian)
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_USER_EMAIL=your@email.com
# JIRA_API_TOKEN=your_jira_api_token

# Azure DevOps
# AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org
# AZURE_DEVOPS_PROJECT=your-project
# AZURE_DEVOPS_PAT=your_personal_access_token
# AZURE_DEVOPS_REPO=your-repo-name

# Target Flask app (for smoke tests)
# APP_SERVICE_URL=https://your-app.azurewebsites.net

# Runtime settings
USE_LLM=false
